# Secrets — 永不提交
.env
.env.*
*.key
*.pem
*.secret

# 私密工具 — agentmail helper (不入仓, 燕如自己用)
# scripts/ 下只放公开工具 (install-hooks.sh)，其他 .py/.sh 一律不仓
scripts/_private/
agentmail.py
scripts/agentmail*
scripts/*.py
scripts/*.sh
!scripts/install-hooks.sh
*.pyc
__pycache__/

# 临时文件
*.tmp
*.bak
*~
.DS_Store
Thumbs.db

# Hugo build 输出 (若未来切 Hugo 框架)
public/
resources/
.hugo_build.lock

# 燕如的 git 身份 (由 ~/.gitconfig 自动加载，本地配置不入仓)
.gitconfig_local

# 燕如自备份 — 永不进 cafe 仓（公开站点，不应混入任何备份内容）
_backups/
_last_self_backup
